<Window x:Class="BeerTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beer Tracker" Height="450" Width="900">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo / Header -->
        <Border Grid.Row="0" Padding="12" CornerRadius="8" Background="#1F1F1F">
            <DockPanel LastChildFill="True">
                <TextBlock Text="🍺 BeerTracker"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           DockPanel.Dock="Left"/>

                <TextBlock Text="Inventory"
                           Foreground="#CFCFCF"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Beer list -->
            <GroupBox Header="Inventory">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Add" Width="70"
                                Command="{Binding AddCommand}" Margin="480, 0, 0, 0"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Beers}"
                             SelectedItem="{Binding SelectedBeer, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" Margin="12,0,0,0"
                                               Text="{Binding Quantity}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- Beer's Details -->
            <GroupBox Grid.Column="2" Header="Details">
                <StackPanel Margin="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold"
                               Text="{Binding SelectedBeer.Name}"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" Text="Quantity:"/>
                        <TextBlock Text="{Binding SelectedBeer.Quantity}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Width="120" Text="Serving size:"/>
                        <TextBlock Text="{Binding SelectedBeer.ServingSize}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Delete"
                                Width="90" Margin="0,0,8,0"
                                Command="{Binding DeleteCommand}"/>

                        <Button Content="Update (later)"
                                Width="120" IsEnabled="False"/>
                    </StackPanel>

                    <TextBlock Margin="0,16,0,0" Foreground="Gray" FontStyle="Italic"
                               Text="Select a beer to see details here."/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </Grid>
</Window>