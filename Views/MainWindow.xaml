<Window x:Class="BeerTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beer Tracker" Height="450" Width="900">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo / Header -->
        <Border Grid.Row="0" Padding="12" CornerRadius="8" Background="#1F1F1F">
            <DockPanel LastChildFill="True">
                <TextBlock Text="🍺 BeerTracker"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           DockPanel.Dock="Left"/>
                <TextBlock Text="Inventory"
                           Foreground="#CFCFCF"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Inventory -->
            <GroupBox Header="Inventory">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Right">
                        <Button Content="Add" Width="70"
                                Command="{Binding AddCommand}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Beers}"
                             SelectedItem="{Binding SelectedBeer, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               Text="{Binding Quantity}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- Details -->
            <GroupBox Grid.Column="2" Header="Details">
                <StackPanel Margin="12">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedBeer.Name}"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Width="120" Text="Quantity:"/>
                        <TextBlock Text="{Binding SelectedBeer.Quantity}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Width="120" Text="Serving size:"/>
                        <TextBlock Text="{Binding SelectedBeer.ServingSize}"/>
                    </StackPanel>

                    <!-- Actions (only show when a beer is selected) -->
                    <StackPanel Margin="0,12,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBeer}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Delete / Edit -->
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button Content="Delete" Margin="0,0,8,0" Command="{Binding DeleteCommand}"/>
                            <Button Content="Edit" Command="{Binding EditCommand}"/>
                        </UniformGrid>

                        <!-- + / - when Quantity > 0 -->
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <UniformGrid.Style>
                                <Style TargetType="UniformGrid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedBeer.Quantity}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </UniformGrid.Style>

                            <Button Content="+" Margin="0,0,8,0" Command="{Binding AddOneCommand}"/>
                            <Button Content="-" Command="{Binding DrinkOneCommand}"/>
                        </UniformGrid>

                        <!-- Drink row centered (hidden at 0) -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedBeer.Quantity}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBox Width="70"
                                     Margin="0,0,8,0"
                                     Text="{Binding DrinkAmount, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Content="Drink"
                                    Width="70"
                                    Command="{Binding DrinkManyCommand}" />
                        </StackPanel>

                        <!-- Restock when Quantity == 0 -->
                        <Button Content="Restock"
                                Height="28"
                                Command="{Binding RestockCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedBeer.Quantity}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Tip only when nothing is selected -->
                    <TextBlock Margin="0,16,0,0"
                               Foreground="Gray"
                               FontStyle="Italic"
                               Text="Select a beer to see details here.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBeer}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </GroupBox>
        </Grid>
    </Grid>
</Window>